<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QuizKu" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>

        <!-- Background Colors -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>

        <!-- Surface Colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_container</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Action Bar -->
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

        <!-- Dialog -->
        <item name="materialAlertDialogTheme">@style/Theme.QuizKu.Dialog</item>
    </style>

    <style name="Theme.QuizKu.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:height">64dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="Theme.QuizKu.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/on_surface</item>
        <item name="backgroundTint">@color/surface_container</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:height">64dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="Theme.QuizKu.Button.Option" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:backgroundTint">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:height">64dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Theme.QuizKu.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Flat input: label + underline -->
    <style name="Theme.QuizKu.InputLabel">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="Theme.QuizKu.Dialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>
    </style>

    <style name="Theme.QuizKu.InputField">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textColorHint">@color/outline</item>
        <item name="android:background">@drawable/bg_input_fill</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:inputType">text</item>
        <item name="android:singleLine">true</item>
    </style>
</resources>
